name: Debug Wikipedia Image Lookup

on:
  workflow_dispatch:  # manual trigger only

jobs:
  debug:
    runs-on: ubuntu-latest
    timeout-minutes: 5

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: pip install requests tavily-python feedparser trendspyg selenium

      - name: Check fetch_trends.py version
        run: |
          echo "=== Checking if Wikipedia functions exist ==="
          grep -n "def extract_wiki_term\|def fetch_wikipedia_image\|topic_image_url" fetch_trends.py | head -20
          echo ""
          echo "=== Line count ==="
          wc -l fetch_trends.py

      - name: Test Wikipedia image lookup
        env:
          SUPABASE_URL:         ${{ vars.SUPABASE_URL }}
          SUPABASE_SERVICE_KEY: ${{ secrets.SUPABASE_SERVICE_KEY }}
          TAVILY_API_KEY:       ${{ secrets.TAVILY_API_KEY }}
        run: |
          python3 << 'PYEOF'
          import sys
          sys.path.insert(0, '.')

          with open('fetch_trends.py') as f:
              src = f.read()

          if 'def extract_wiki_term' not in src:
              print('FAIL: extract_wiki_term not in fetch_trends.py -- old version deployed')
              sys.exit(1)
          if 'def fetch_wikipedia_image' not in src:
              print('FAIL: fetch_wikipedia_image not in fetch_trends.py')
              sys.exit(1)
          if 'topic_image_url' not in src:
              print('FAIL: topic_image_url not in fetch_trends.py')
              sys.exit(1)

          print('OK: All Wikipedia functions present')
          print()

          from fetch_trends import extract_wiki_term, fetch_wikipedia_image

          tests = [
              'czech republic national football team vs mexico national football team standings',
              'is south korea out of the world cup',
              'elon musk loses trillionaire status',
              'mirra andreeva',
              'gta 6',
              'earthquake near me',
              'primary elections',
              'dustin poirier arrested',
          ]

          print('=== Wikipedia Image Lookup Results ===')
          found = 0
          for t in tests:
              terms = extract_wiki_term(t)
              url   = fetch_wikipedia_image(t)
              ok    = bool(url)
              if ok: found += 1
              print(f'{"OK" if ok else "MISS"} | {t[:55]}')
              print(f'     terms: {terms}')
              print(f'     image: {url[:100] if url else "NONE"}')
              print()

          print(f'=== {found}/{len(tests)} topics got Wikipedia images ===')
          PYEOF
